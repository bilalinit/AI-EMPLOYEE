# AI Employee Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# VAULT PATH
# =============================================================================
# Path to your Obsidian AI_Employee_Vault
VAULT_PATH=../AI_Employee_Vault

# =============================================================================
# WATCHER SETTINGS
# =============================================================================
# How often to check for updates (seconds)
# Note: File system watcher is event-based and doesn't use this
CHECK_INTERVAL=60

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# LINKEDIN (API MCP - REST API)
# =============================================================================
# LinkedIn OAuth 2.0 credentials for REST API access
# Get these from: https://www.linkedin.com/developers/tools
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# LINKEDIN (Playwright MCP - Browser Automation)
# =============================================================================
# Path for storing LinkedIn session data (keeps you logged in)
LINKEDIN_SESSION_PATH=./sessions/linkedin_session

# =============================================================================
# TWITTER/X MCP
# =============================================================================
# Twitter/X OAuth 1.0a credentials
# Get these from: https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# =============================================================================
# META MCP (Facebook/Instagram)
# =============================================================================
# Meta Graph API Long-Lived Token (valid for 60 days)
# Get this from: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_long_lived_token_here

# Your Facebook Page ID (for posting to Facebook Page)
# Find this at: https://developers.facebook.com/tools/debug/accesstoken/
# or use /get-page-id-helper MCP tool
META_PAGE_ID=your_page_id_here

# =============================================================================
# ODOO ACCOUNTING (Gold Tier)
# =============================================================================
# Odoo Community 19 - Self-hosted accounting via MCP
# After starting docker-compose, access at: http://localhost:8069
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin@example.com
ODOO_PASSWORD=change_this_password

# =============================================================================
# WATCHDOG (Optional)
# =============================================================================
# Set to 'true' to run watchdog in monitoring-only mode (no auto-restart)
# WATCHDOG_ONLY_MONITOR=false

# =============================================================================
# DEVELOPMENT
# =============================================================================
# Set to 'true' to prevent actual external actions (for testing)
DRY_RUN=true
