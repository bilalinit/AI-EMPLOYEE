# AI Employee Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# VAULT PATH
# =============================================================================
# Path to your Obsidian AI_Employee_Vault
VAULT_PATH=../AI_Employee_Vault

# =============================================================================
# WATCHER SETTINGS
# =============================================================================
# How often to check for updates (seconds)
# Note: File system watcher is event-based and doesn't use this
CHECK_INTERVAL=60

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# GMAIL WATCHER (Silver Tier)
# =============================================================================
# GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
# GMAIL_TOKEN_PATH=./credentials/gmail_token.json

# =============================================================================
# WHATSAPP WATCHER (Gold Tier)
# =============================================================================
# WHATSAPP_SESSION_PATH=./sessions/whatsapp_session

# =============================================================================
# LINKEDIN API MCP (Silver Tier)
# =============================================================================
# LinkedIn OAuth 2.0 access token for API access
# Get this from: https://www.linkedin.com/developers/tools
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# ODOO ACCOUNTING (Gold Tier)
# =============================================================================
# Odoo Community 19 - Self-hosted accounting via MCP
# After starting docker-compose, access at: http://localhost:8069
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin@example.com
ODOO_PASSWORD=change_this_password

# =============================================================================
# MCP SERVERS (Silver/Gold Tier)
# =============================================================================
# Email MCP
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=your-email@gmail.com

# =============================================================================
# DEVELOPMENT
# =============================================================================
# Set to 'true' to prevent actual external actions
DRY_RUN=true
