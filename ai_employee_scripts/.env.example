# AI Employee Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# VAULT PATH
# =============================================================================
# Path to your Obsidian AI_Employee_Vault
VAULT_PATH=../AI_Employee_Vault

# =============================================================================
# WATCHER SETTINGS
# =============================================================================
# How often to check for updates (seconds)
# Note: File system watcher is event-based and doesn't use this
CHECK_INTERVAL=60

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# LINKEDIN (API MCP - REST API)
# =============================================================================
# LinkedIn OAuth 2.0 credentials for REST API access
# Get these from: https://www.linkedin.com/developers/tools
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# LINKEDIN (Playwright MCP - Browser Automation)
# =============================================================================
# Path for storing LinkedIn session data (keeps you logged in)
LINKEDIN_SESSION_PATH=./sessions/linkedin_session

# =============================================================================
# TWITTER/X MCP
# =============================================================================
# Twitter/X OAuth 1.0a credentials
# Get these from: https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# =============================================================================
# META MCP (Facebook/Instagram)
# =============================================================================
# Meta Graph API Long-Lived Token (valid for 60 days)
# Get this from: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_long_lived_token_here

# Your Facebook Page ID (for posting to Facebook Page)
# Find this at: https://developers.facebook.com/tools/debug/accesstoken/
# or use /get-page-id-helper MCP tool
META_PAGE_ID=your_page_id_here

# =============================================================================
# ODOO ACCOUNTING (Gold Tier)
# =============================================================================
# Odoo Community 19 - Self-hosted accounting via MCP
# After starting docker-compose, access at: http://localhost:8069
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin@example.com
ODOO_PASSWORD=change_this_password

# =============================================================================
# WATCHDOG (Optional)
# =============================================================================
# Set to 'true' to run watchdog in monitoring-only mode (no auto-restart)
# WATCHDOG_ONLY_MONITOR=false

# =============================================================================
# DEVELOPMENT
# =============================================================================
# Set to 'true' to prevent actual external actions (for testing)
DRY_RUN=true

# =============================================================================
# PLATINUM TIER - CLOUD AGENT (OpenAI Agents SDK)
# =============================================================================
# Agent type: 'cloud' or 'local'
AGENT_TYPE=local

# Xiaomi API for cloud agent drafting
# Get your API key from: https://api.xiaomimimo.com/
XIAOMI_API_KEY=your_xiaomi_api_key_here

# Xiaomi model to use
MODEL_NAME=glm-4.7-flash

# Xiaomi API endpoint (default)
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1/

# Cloud agent check intervals (seconds)
NEEDS_ACTION_CHECK_INTERVAL=30
GIT_SYNC_INTERVAL=300

# =============================================================================
# PLATINUM TIER - CLOUD WATCHERS (24/7 Operation)
# =============================================================================
# These credentials are for the cloud VM to run watchers independently

# Gmail Service Account (for cloud Gmail watcher)
# Create a service account at: https://console.cloud.google.com/apis/credentials
# Download JSON key and provide path (or copy contents for env var)
GMAIL_CREDENTIALS_PATH=./cloud_credentials.json

# Alternative: Direct service account key (for .env)
# GMAIL_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Gmail user/alias to monitor (uses "me" for authenticated account)
GMAIL_USER_EMAIL=me

# LinkedIn API credentials (for cloud LinkedIn watcher)
# Get access token from: https://developer.linkedin.com/docs/oauth2
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_URN=your_linkedin_profile_urn_here

# =============================================================================
# DEDUPLICATION API (Local/Cloud Coordination)
# =============================================================================
# URL of the dedup API server for preventing duplicate processing
# Local watcher: http://YOUR_CLOUD_IP:5000 (connects to cloud API)
# Cloud watcher: http://localhost:5000 (API runs on same VM)
DEDUP_API_URL=http://localhost:5000

# Optional: API key for dedup server authentication
# DEDUP_API_KEY=your_secret_key_here

# Optional: Port for dedup API server (default: 5000)
# DEDUP_API_PORT=5000

